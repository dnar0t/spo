{
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true,
      "useDefineForClassFields": false
    },
    "target": "es2021",
    "keepClassNames": true
  },
  "module": {
    "type": "commonjs"
  },
  "swcrc": false
}
