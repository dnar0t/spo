{
  "name": "@spo/backend",
  "version": "1.0.0",
  "description": "NestJS backend for СПО (Система Планирования и Отчетности)",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "prisma:generate": "prisma generate --schema=src/infrastructure/prisma/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=src/infrastructure/prisma/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=src/infrastructure/prisma/prisma/schema.prisma",
    "prisma:seed": "ts-node --compiler-options '{\"module\":\"commonjs\"}' prisma/seed.ts",
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --config jest.config.ts --watch",
    "test:coverage": "jest --config jest.config.ts --coverage"
  },
  "prisma": {
    "seed": "ts-node --compiler-options '{\"module\":\"commonjs\"}' prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^3.0.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.11.0",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.7.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.0",
    "jest": "^30.3.0",
    "prisma": "^5.11.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
