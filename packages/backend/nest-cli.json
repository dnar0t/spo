{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "swc",
    "typeCheck": false,
    "tsConfigPath": "tsconfig.build.json",
    "plugins": [],
    "options": {
      "swc": {
        "jsc": {
          "parser": {
            "syntax": "typescript",
            "decorators": true,
            "dynamicImport": true
          },
          "transform": {
            "legacyDecorator": true,
            "decoratorMetadata": true
          },
          "target": "es2021",
          "keepClassNames": true
        },
        "module": {
          "type": "commonjs"
        }
      }
    }
  }
}
