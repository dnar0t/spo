{
  "name": "spo",
  "version": "1.0.0",
  "private": true,
  "description": "Система Планирования и Отчетности (СПО)",
  "workspaces": [
    "packages/backend",
    "packages/shared"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:backend": "npm run build -w packages/backend",
    "build:shared": "npm run build -w packages/shared",
    "dev": "npm run dev -w packages/backend",
    "start": "npm run start -w packages/backend",
    "start:prod": "npm run start:prod -w packages/backend",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "format": "prettier --write 'packages/*/src/**/*.ts'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "~5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
